# ═══════════════════════════════════════════════════
# realang.store 환경변수 (.env.example)
# 복사: cp .env.example .env.local
# ═══════════════════════════════════════════════════

# ── OpenAI (필수: AI 코스/플래너/챗봇/차종추천) ──
OPENAI_API_KEY=sk-...

# ── Supabase (필수: 데이터 저장, 인증) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── 공공데이터포털 (필수: 날씨, 관광 POI) ──
DATA_GO_KR_KEY=...

# ── 네이버 검색 API (선택: 지도 POI 벌크 수집) ──
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...

# ── 카카오 (선택: 지도 JS SDK) ──
NEXT_PUBLIC_KAKAO_JS_KEY=...
KAKAO_REST_API_KEY=...

# ── VWorld (선택: 지도 타일) ──
VWORLD_API_KEY=...
